{
  "name": "koishi-plugin-aka-ai-image-generator",
  "version": "0.5.3",
  "description": "AI image generator for Koishi (V2: semantic supplier UI with OpenAI-compatible image protocols).",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "peerDependencies": {
    "koishi": "^4.18.9"
  },
  "dependencies": {
    "jimp": "^0.22.10"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "koishi": "^4.18.9",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chatbot",
    "koishi",
    "koishi-plugin",
    "ai",
    "image-generation",
    "openai-compatible",
    "openai-official",
    "gemini-official",
    "openai-images",
    "openai-chat",
    "gemini"
  ]
}
