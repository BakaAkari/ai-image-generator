{
  "name": "koishi-plugin-aka-ai-image-generator",
  "version": "0.1.0",
  "description": "AI image & video generator for Koishi (V2: provider-registry architecture, multi-model adaptive).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "koishi": "^4.18.9"
  },
  "dependencies": {
    "jimp": "^0.22.10"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "koishi": "^4.18.9",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chatbot",
    "koishi",
    "koishi-plugin",
    "ai",
    "image-generation",
    "video-generation",
    "yunwu",
    "gptgod",
    "gemini",
    "openai"
  ]
}
